{
  "name": "elegance-js",
  "version": "3.0.6",
  "type": "module",
  "main": "dist/user-utils.js",
  "bin": {
    "bootstrap": "./bin/bootstrap.js",
    "elegance": "./bin/run.js",
    "export": "./bin/export.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "lint": "oxlint ./src --fix -D unused-variable -D unused-import",
    "build": "esbuild './src/*.ts' './src/**/*.ts' --outdir=./dist --outbase=./src --format=esm --platform=node --bundle=false && tsc --emitDeclarationOnly && node scripts/fix-imports.js"
  },
  "exports": {
    ".": {
      "types": "./dist/user-utils.d.ts",
      "import": "./dist/user-utils.js",
      "default": "./dist/user-utils.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts"
    },
    "./run": {
      "types": "./dist/run.d.ts",
      "import": "./dist.run.js",
      "default": "./dist.run.js",
      "require": "./dist.run.js"
    }
  },
  "author": "vqldemar <npm-elegance@val.sh> (https://github.com/valdemar-dev)",
  "keywords": [
    "elegance",
    "elegance-js",
    "css",
    "jsx",
    "tsx",
    "web-framework",
    "framework",
    "web",
    "html",
    "javascript",
    "typescript",
    "js",
    "ts",
    "web-dev",
    "web",
    "speed",
    "fast",
    "optimized"
  ],
  "license": "MIT",
  "github": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/valdemar-dev/elegance-js"
  },
  "bugs": {
    "url": "https://github.com/valdemar-dev/elegance-js/issues"
  },
  "dependencies": {
    "esbuild": "^0.28.0",
    "oxc-parser": "^0.127.0",
    "ts-arc": "^1.3.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "oxlint": "^1.68.0",
    "typescript": "^5.0.0"
  }
}
