{
  "name": "elegance-js",
  "version": "2.1.37",
  "description": "Web-Framework",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "run": "./scripts/run.js",
    "static": "./scripts/static.js",
    "prod": "./scripts/prod.js",
    "bootstrap": "./scripts/bootstrap.js"
  },
  "scripts": {
    "build": "npx tsc --project tsconfig.json --rootDir ./src --outDir ./dist && node ./build_scripts/fix_imports.js",
    "prepare": "npm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.js"
    }
  },
  "files": [
    "dist",
    "scripts"
  ],
  "author": "vqldemar",
  "license": "MIT",
  "dependencies": {
    "@swc/core": "^1.15.30",
    "esbuild": "^0.25.9",
    "ts-arc": "^1.3.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.3",
    "@types/node": "^22.19.17",
    "tailwindcss": "^4.0.3",
    "typescript": "^5.8.2"
  }
}
