{
  "name": "elegance-js",
  "version": "2.1.23",
  "description": "Web-Framework",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "run": "./scripts/run.js",
    "bootstrap": "./scripts/bootstrap.js"
  },
  "scripts": {
    "build": "esbuild --format=esm --platform=node --bundle=false --outdir=./dist --out-extension:.js=.mjs \"./src/**/*.ts\" && esbuild --format=esm --platform=browser --bundle=true --outfile=./dist/client/runtime.mjs --out-extension:.js=.mjs ./src/client/runtime.ts && tsc ",
    "compile-docs": "node ./dist/compile_docs.mjs --environment=development",
    "compile-docs-bun": "bun run ./dist/compile_docs.mjs --environment=development",
    "prepare": "npm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.mjs"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.mjs",
      "require": "./dist/*.mjs"
    }
  },
  "files": [
    "dist",
    "scripts"
  ],
  "author": "vqldemar",
  "license": "MIT",
  "dependencies": {
    "esbuild": "^0.25.9",
    "ts-arc": "^1.1.29"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.3",
    "@types/node": "^22.18.12",
    "tailwindcss": "^4.0.3",
    "typescript": "^5.8.2"
  }
}
